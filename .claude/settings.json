{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git fetch:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git branch:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(git stash:*)",
      "Bash(git tag:*)",
      "Bash(git restore:*)",
      "Bash(git cherry-pick:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git blame:*)",
      "Bash(git remote:*)",
      "Bash(git config --get:*)",
      "Bash(git config --list:*)",
      "Bash(gh pr:*)",
      "Bash(gh issue:*)",
      "Bash(gh repo view:*)",
      "Bash(gh run view:*)",
      "Edit(/.claude/skills/**)",
      "Edit(/.claude/skills/tla/**)",
      "Edit(/.claude/skills/sync-template/**)",
      "Bash(mkdir -p /Users/jool/repos/Claude/.claude/validation)",
      "Bash(echo \".claude/validation/\")",
      "Edit(/.claude/skills/allium/**)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(sudo *)",
      "Bash(git push --force*)",
      "Bash(git push *--force*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.azure/**)",
      "Read(~/.config/gh/**)",
      "Read(~/.git-credentials)",
      "Read(~/.docker/config.json)",
      "Read(~/.npmrc)",
      "Edit(~/.bashrc)",
      "Edit(~/.zshrc)",
      "Edit(~/.ssh/**)"
    ],
    "ask": [],
    "additionalDirectories": []
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); if printf '%s' \"$INPUT\" | bash \"$CLAUDE_PROJECT_DIR/scripts/pipeline-trigger-match.sh\" pipeline; then bash \"$CLAUDE_PROJECT_DIR/scripts/emit-pipeline-reminder.sh\"; fi"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); if printf '%s' \"$INPUT\" | bash \"$CLAUDE_PROJECT_DIR/scripts/pipeline-trigger-match.sh\" analyze; then bash \"$CLAUDE_PROJECT_DIR/scripts/emit-analyze-reminder.sh\"; fi"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); if printf '%s' \"$INPUT\" | bash \"$CLAUDE_PROJECT_DIR/scripts/pipeline-trigger-match.sh\" clarify; then bash \"$CLAUDE_PROJECT_DIR/scripts/emit-clarify-reminder.sh\"; fi"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/local-llm-classify-hook.sh\""
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/feature-pipeline-detect.sh\"",
            "statusMessage": "Checking for feature-pipeline trigger..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); FILE=$(echo \"$INPUT\" | jq -r '.tool_input.file_path // empty' 2>/dev/null); if [ -n \"$FILE\" ] && echo \"$FILE\" | grep -qE '(/\\.ssh/|/\\.aws/|/\\.azure/|/\\.git-credentials|/\\.docker/config\\.json|/\\.config/gh/|\\.env$|\\.env\\.)'; then echo '{\"hookSpecificOutput\": {\"permissionDecision\": \"deny\", \"permissionDecisionReason\": \"Blocked: access to sensitive files is not allowed\"}}'; fi"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/spec-register-guard-hook.sh\"",
            "statusMessage": "Checking spec register exists..."
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/pipeline-state-guard-hook.sh\"",
            "statusMessage": "Checking pipeline phase completion..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/ui-design-hook.sh\""
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/sqlite-nfs-safety-hook.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "CMD=$(python3 -c \"import json,sys; d=json.load(sys.stdin); print(d.get('tool_input',d).get('command',''))\" 2>/dev/null || true); case \"$CMD\" in *grep*|*rg\\ *|*ripgrep*|*find\\ *|*fd\\ *|*ack\\ *|*ag\\ *)   [ -f graphify-out/graph.json ] &&   echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"graphify: knowledge graph at graphify-out/. For focused questions, run `graphify query \\\"<question>\\\"` (scoped subgraph, usually much smaller than GRAPH_REPORT.md) instead of grepping raw files. Read GRAPH_REPORT.md only for broad architecture context.\"}}'   || true ;; esac"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(cat | jq -r '.tool_input.file_path // empty' 2>/dev/null); if [ -n \"$FILE\" ] && echo \"$FILE\" | grep -qE '\\.(cs|csproj)$'; then echo '{\"systemMessage\": \"Reminder: run dotnet build to verify compilation\"}'; fi"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/spec-md-coverage-reminder-hook.sh\"",
            "statusMessage": "Validating spec completeness..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/test-coverage-hook.sh\"",
            "statusMessage": "Checking functional test coverage..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/tla-hook.sh\"",
            "statusMessage": "Checking for TLA+ verification..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/allium-hook.sh\"",
            "statusMessage": "Checking for Allium specification..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/after-specify-hook.sh\"",
            "statusMessage": "after_specify: auto-commit check..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/local-llm-changelog-hook.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/local-llm-readme-skeleton-hook.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/local-llm-gitignore-skeleton-hook.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/local-llm-dotenv-example-hook.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/local-llm-n1-query-hook.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/local-llm-migration-safety-hook.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/local-llm-react-deps-hook.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/local-llm-dockerfile-review-hook.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/local-llm-async-audit-hook.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/local-llm-allium-openq-hook.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat | jq -r '.tool_input.command // empty' 2>/dev/null); if echo \"$INPUT\" | grep -qiE '(tlc|tla2tools|tlc2\\.TLC)'; then bash \"$CLAUDE_PROJECT_DIR/scripts/tlc-cleanup.sh\" 2>/dev/null; fi"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/local-llm-commit-draft-hook.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/local-llm-pr-draft-hook.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/local-llm-gh-run-view-hook.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/local-llm-gh-pr-view-hook.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/local-llm-gh-issue-view-hook.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/local-llm-bash-tldr-hook.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/local-llm-stacktrace-hook.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/local-llm-tlc-translate-hook.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); CMD=$(echo \"$INPUT\" | jq -r '.tool_input.command // empty' 2>/dev/null); EXIT=$(echo \"$INPUT\" | jq -r '.tool_response.interrupted // false' 2>/dev/null); if echo \"$CMD\" | grep -qiE '(Category=UI|playwright|npx playwright|pnpm.*playwright|yarn.*playwright)'; then jq -n '{hookSpecificOutput: {hookEventName: \"PostToolUse\", additionalContext: \"BROWSER TESTS COMPLETED \u2014 BLOCKING VALIDATION REQUIRED before declaring work done:\\n\\n(1) SPEC COMPLIANCE: Open the feature spec and its FUNCTIONAL COVERAGE section. Enumerate every implemented function. Confirm each has a passing browser test AND that the assertion actually verifies the spec behavior (not just that the page loaded). If ANY function lacks a real test, the task is NOT done \u2014 write the missing tests now.\\n\\n(2) DESIGN COMPLIANCE: Invoke the frontend-design skill via the Skill tool and verify the UI follows its recommendations (typography scale, spacing rhythm, color palette, component polish, accessibility, responsive behavior, distinctive design \u2014 not generic AI aesthetic). If any violations exist, fix them before declaring done.\\n\\nDo NOT skip either step. Do NOT declare the task complete until both validations pass. Report findings explicitly: which functions were verified, which design checks passed/failed.\"}}'; fi",
            "statusMessage": "Enforcing post-browser-test validation..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/graphify-fire-hook.sh\"",
            "statusMessage": "Logging graphify invocation telemetry..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/tlc-cleanup.sh\" 2>/dev/null; true"
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/continuous-execution-hook.sh\"",
            "statusMessage": "Checking for phase-splitting anti-pattern..."
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/stop-validation-hook.sh\"",
            "statusMessage": "Validating spec + design compliance before stop..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"systemMessage\": \"IMPORTANT: Preserve the full list of modified files, error messages, test commands, and current task context during compaction.\"}'"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"systemMessage\": \"Context was compacted. Re-read any files you were working on before continuing.\"}'"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/local-llm-orientation-hook.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/spec-register-orientation-hook.sh\""
          }
        ]
      }
    ]
  },
  "language": "english"
}
